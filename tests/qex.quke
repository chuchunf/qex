feature .dailyops

    before 
        system "cd qex"

    before
        system "l qex.q"
    
    after
        system "cd .."

    should "be able to validate an order before anythng else" 
        expect "failed if order missing mandatory field"
            o:(`sym1`side1`otype1`osize1) ! (`ABC;`BUY;`MARKET;100);
            .qex.validateOrder[o] = 0b;
